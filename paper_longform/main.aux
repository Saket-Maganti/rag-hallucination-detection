\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The refinement paradox persists at frontier scale.} Per-passage refinement (HCPC-v1, red) drops faithfulness below the no-refinement baseline (blue) on SQuAD across a $17\times $ generator scale range (Mistral-$7$B $\to $ Llama-$3.3$-$70$B $\to $ GPT-OSS-$120$B). HCPC-v$2$ (green), which gates refinement on a coherence-loss check, recovers the lost faithfulness on every cell. Paradox magnitude $\Delta =\textrm  {faith}_{\textrm  {base}}-\textrm  {faith}_{\textrm  {v1}}$ annotated above each pair. PubMedQA paradox attenuates at scale --- a prediction the coherence account makes (stronger parametric priors are better substitutes for fragmented biomedical evidence) --- but does not invert. See \S  \ref {sec:robustness} for the full table.}}{6}{figure.caption.20}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:headline_frontier}{{1}{6}{\textbf {The refinement paradox persists at frontier scale.} Per-passage refinement (HCPC-v1, red) drops faithfulness below the no-refinement baseline (blue) on SQuAD across a $17\times $ generator scale range (Mistral-$7$B $\to $ Llama-$3.3$-$70$B $\to $ GPT-OSS-$120$B). HCPC-v$2$ (green), which gates refinement on a coherence-loss check, recovers the lost faithfulness on every cell. Paradox magnitude $\Delta =\textrm {faith}_{\textrm {base}}-\textrm {faith}_{\textrm {v1}}$ annotated above each pair. PubMedQA paradox attenuates at scale --- a prediction the coherence account makes (stronger parametric priors are better substitutes for fragmented biomedical evidence) --- but does not invert. See \S \ref {sec:robustness} for the full table}{figure.caption.20}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}The Refinement Paradox}{6}{section.4}\protected@file@percent }
\newlabel{sec:paradox}{{4}{6}{The Refinement Paradox}{section.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces The refinement paradox at the canonical operating point. Mistral-$7$B, SQuAD, $k=3$, chunk $= 1024$, $n=30$ per condition. HCPC-v$1$ \emph  {maintains or improves} retrieval similarity while \emph  {degrading} faithfulness and introducing hallucination. HCPC-v$2$ recovers faithfulness while intervening on $16.7\%$ of queries.}}{6}{table.caption.21}\protected@file@percent }
\newlabel{tab:hcpc_main}{{1}{6}{The refinement paradox at the canonical operating point. Mistral-$7$B, SQuAD, $k=3$, chunk $= 1024$, $n=30$ per condition. HCPC-v$1$ \emph {maintains or improves} retrieval similarity while \emph {degrading} faithfulness and introducing hallucination. HCPC-v$2$ recovers faithfulness while intervening on $16.7\%$ of queries}{table.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}The mechanism: it is the \emph  {set}, not the passages}{7}{subsection.4.1}\protected@file@percent }
\newlabel{sec:paradox:mechanism}{{4.1}{7}{The mechanism: it is the \emph {set}, not the passages}{subsection.4.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Qualitative example of the refinement paradox on squad with mistral. Per-passage refinement raises retrieval similarity but strips the connective evidence the generator was relying on; the generator silently fills the gap with a plausible but unsupported claim.}}{7}{figure.caption.22}\protected@file@percent }
\newlabel{fig:qualitative_paradox}{{2}{7}{Qualitative example of the refinement paradox on squad with mistral. Per-passage refinement raises retrieval similarity but strips the connective evidence the generator was relying on; the generator silently fills the gap with a plausible but unsupported claim}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Disentangling coherence from relevance}{8}{subsection.4.2}\protected@file@percent }
\newlabel{sec:paradox:disentangle}{{4.2}{8}{Disentangling coherence from relevance}{subsection.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Coherence is causally distinct from relevance.} Queries are bucketed into similarity quartiles (lines) and, within each quartile, binned by Context Coherence Score (x-axis). Faithfulness varies meaningfully along the coherence axis \emph  {even at fixed similarity quartiles}: at high CCS the curves rise toward $0.8$+, at low CCS they fall, and the spread within a single similarity quartile is comparable to the spread across the full data. If coherence were a re-statement of relevance, the lines would be flat. Shaded bands are 95\% bootstrap CIs over $n \geq 3$ queries per cell.}}{8}{figure.caption.23}\protected@file@percent }
\newlabel{fig:disentanglement}{{3}{8}{\textbf {Coherence is causally distinct from relevance.} Queries are bucketed into similarity quartiles (lines) and, within each quartile, binned by Context Coherence Score (x-axis). Faithfulness varies meaningfully along the coherence axis \emph {even at fixed similarity quartiles}: at high CCS the curves rise toward $0.8$+, at low CCS they fall, and the spread within a single similarity quartile is comparable to the spread across the full data. If coherence were a re-statement of relevance, the lines would be flat. Shaded bands are 95\% bootstrap CIs over $n \geq 3$ queries per cell}{figure.caption.23}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}What HCPC-v$2$ actually does}{8}{subsection.4.3}\protected@file@percent }
\newlabel{sec:paradox:v2_intuition}{{4.3}{8}{What HCPC-v$2$ actually does}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Coherent vs incoherent retrieval sets, visualized.} Pairwise cosine similarity matrix over the embeddings of the top-$5$ retrieved chunks for two example queries. Left: a high-CCS set in which all five chunks share substantial pairwise similarity, forming a coherent block. Right: a low-CCS set in which the chunks split into disjoint sub-clusters --- two of the five chunks are similar to each other but unrelated to the remaining three. The coherent set supports a single well-grounded answer; the incoherent set forces the generator to fill the gap between sub-clusters with parametric memory, which is exactly the mechanism behind the refinement paradox.}}{9}{figure.caption.24}\protected@file@percent }
\newlabel{fig:coherence_heatmap}{{4}{9}{\textbf {Coherent vs incoherent retrieval sets, visualized.} Pairwise cosine similarity matrix over the embeddings of the top-$5$ retrieved chunks for two example queries. Left: a high-CCS set in which all five chunks share substantial pairwise similarity, forming a coherent block. Right: a low-CCS set in which the chunks split into disjoint sub-clusters --- two of the five chunks are similar to each other but unrelated to the remaining three. The coherent set supports a single well-grounded answer; the incoherent set forces the generator to fill the gap between sub-clusters with parametric memory, which is exactly the mechanism behind the refinement paradox}{figure.caption.24}{}}
