*.zip
*.tar.gz

# Local vector DBs / generated DBs
chroma_db*/
*.sqlite3
artifacts/generated/chroma_db*/

# Generated/staging snapshots
space_deploy/
hf_dataset_staging/
artifacts/generated/*
!artifacts/generated/README.md

# Archived local generated material. Keep README files tracked.
archive/legacy_chroma_dbs/*
!archive/legacy_chroma_dbs/README.md
archive/old_logs/*
!archive/old_logs/README.md
archive/old_zips/*
!archive/old_zips/README.md

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# Agent/worktree state
.claude/

# Large local office artifacts
*.docx
*.xlsx

# Historical backup folders, if recreated locally
ragpaper.v2_backup/
